{
  "name": "HA Integration Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",

  "workspaceFolder": "/workspace",

  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "source=${localWorkspaceFolder}/integration/config,target=/config,type=bind",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:HOME}/.codex/skills,target=/root/.codex/skills,type=bind,readonly",
    "source=gh-config,target=/root/.config/gh,type=volume",
    "source=${localEnv:HOME}/Projects/smartly-platform/docs/smartly-device-card-capability-spec.md,target=/workspace/docs/smartly-device-card-capability-spec.md,type=bind"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "bungle.vscode-home-assistant",
        "ms-python.black-formatter",
        "ms-python.isort",
        "openai.chatgpt"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  "postCreateCommand": "apt-get update && apt-get install -y gh bash docker-cli docker-compose && python -m pip install --upgrade pip && python -m pip install -r requirements-dev.txt",

  "remoteUser": "root",

  "remoteEnv": {
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  }
}
